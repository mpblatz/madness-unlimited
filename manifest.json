{
    "manifest_version": 3,
    "name": "Madness Unlimited",
    "version": "1.0.0",
    "description": "Unlimited Access To March Madness Live",
    "permissions": ["cookies"],
    "host_permissions": ["*://*.ncaa.com/*"],
    "background": {
        "service_worker": "dist/background.js"
    },
    "content_scripts": [
        {
            "matches": ["*://*.ncaa.com/*"],
            "js": ["dist/content.js"],
            "css": ["content.css"],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["icons/icon128-transparent.png", "fonts/united-italic.otf"],
            "matches": ["*://*.ncaa.com/*"]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
